# ============================================================================
# Virtual Factory Demo — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# ── Supabase (required for data sync & CWF AI agent) ───────────────────────
# Frontend client — uses the anon (public) key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...your-anon-key

# Serverless functions — uses the service_role (private) key
# WARNING: Never expose this in frontend code or commit it to git
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...your-service-role-key

# ── Google Gemini AI (required for CWF Chat With Factory agent) ─────────────
GEMINI_API_KEY=AIza...your-gemini-api-key

# ── Optional ────────────────────────────────────────────────────────────────
# Base path for static assets (default: auto-detected from deployment URL)
# VITE_ASSET_BASE_PATH=/

# Log level: 'debug' | 'info' | 'warn' | 'error' (default: 'debug' in dev, 'info' in prod)
# VITE_LOG_LEVEL=debug
